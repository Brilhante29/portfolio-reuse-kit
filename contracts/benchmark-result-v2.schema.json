{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.local/contracts/benchmark-result-v2.schema.json",
  "title": "Portfolio benchmark result v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "project", "benchmark_id", "workload", "metrics", "execution", "environment", "provenance", "comparability_key"],
  "properties": {
    "schema_version": { "const": 2 },
    "run_id": { "type": "string", "format": "uuid" },
    "project": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "benchmark_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "fixture_digest", "config_digest", "warmup_iterations", "measured_iterations", "concurrency"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "fixture_digest": { "$ref": "#/$defs/sha256" },
        "config_digest": { "$ref": "#/$defs/sha256" },
        "warmup_iterations": { "type": "integer", "minimum": 0 },
        "measured_iterations": { "type": "integer", "minimum": 1 },
        "concurrency": { "type": "integer", "minimum": 1 }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "unit", "direction", "samples", "failures", "summary"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": "number" },
          "unit": { "type": "string", "minLength": 1 },
          "direction": { "enum": ["higher_is_better", "lower_is_better", "target"] },
          "samples": { "type": "array", "minItems": 1, "items": { "type": "number" } },
          "failures": { "type": "integer", "minimum": 0 },
          "summary": { "type": "object" }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "started_at", "duration_seconds", "exit_code", "repeat"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "started_at": { "type": "string", "format": "date-time" },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "exit_code": { "const": 0 },
        "repeat": { "type": "integer", "minimum": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["runtime", "architecture", "hardware_class"],
      "properties": {
        "runtime": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "hardware_class": { "type": "string", "minLength": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_commit", "clean_tree", "image_ref", "image_digest", "dependency_lock_digest", "producer", "artifact_digest"],
      "properties": {
        "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "clean_tree": { "const": true },
        "image_ref": { "type": "string", "minLength": 1 },
        "image_digest": { "$ref": "#/$defs/sha256" },
        "dependency_lock_digest": { "$ref": "#/$defs/sha256" },
        "producer": { "enum": ["local", "github-actions", "other-ci"] },
        "ci_run_url": { "type": "string", "format": "uri" },
        "artifact_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "comparability_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]*$" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
